{
  "name": "interactive-tutorials",
  "version": "0.1.0",
  "private": true,
  "description": "给程序员的交互式技术课程",
  "type": "module",
  "workspaces": [
    "database/*",
    "messaging/*",
    "search/*",
    "rpc/*"
  ],
  "scripts": {
    "dev": "vitepress dev",
    "build": "node scripts/build.mjs",
    "preview": "vitepress preview",
    "serve": "vitepress build && vitepress preview --host --port 5173",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.5",
    "jsdom": "^29.0.0",
    "typescript": "^5.3.0",
    "vitepress": "^1.0.0-rc.31",
    "vitest": "^1.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "overrides": {
    "glob": "^13.0.0"
  }
}
